{
  "rules": [
    {
      "if_contains": "USD",
      "map_to": {
        "scenario_type": "FX_SHOCK",
        "stress_level": "HIGH"
      }
    },
    {
      "if_contains": "IDR weakens",
      "map_to": {
        "scenario_type": "CURRENCY_DEPRECIATION",
        "stress_level": "HIGH"
      }
    },
    {
      "if_contains": "liquidity",
      "map_to": {
        "scenario_type": "LIQUIDITY_CONTRACTION",
        "stress_level": "MEDIUM"
      }
    },
    {
      "if_contains": "volatility",
      "map_to": {
        "scenario_type": "VOLATILITY_SPIKE",
        "stress_level": "MEDIUM"
      }
    }
  ],

  "output": {
    "default_scenario_type": "GENERAL_STRESS",
    "default_stress_level": "LOW",
    "route": [
      "SP-01",
      "SP-02",
      "SP-03",
      "SP-04",
      "SP-05"
    ]
  }
}
