function runSim(type) {

    const output = document.getElementById("output");
    const status = document.getElementById("status");

    // Safety check (prevents blank screen crashes)
    if (!output || !status) {
        console.log("UI elements missing");
        return;
    }

    status.innerText = "RUNNING";

    try {

        // CASCADE MODE
        if (type === "cascade") {

            const result = runSimulation({
                name: "SYNTHETIC STRESS SCENARIO",
                oil_price: 105,
                capital_flow: "outflow",
                inflation_pressure: "rising"
            });

            if (!result) {
                throw new Error("No engine response");
            }

            window.lastSimulationResult = result;

            status.innerText = result.final_state || "UNKNOWN";

            status.style.color =
                result.final_state === "GREEN" ? "lime" :
                result.final_state === "AMBER" ? "orange" :
                result.final_state === "RED" ? "red" :
                "white";

            output.innerHTML =
                "<h3>SEXTANT ENGINE OUTPUT</h3>" +
                "<p><b>Scenario:</b> " + result.scenario + "</p>" +
                "<p><b>FX:</b> " + result.fx.usd_idr + "</p>" +
                "<p><b>System:</b> " + result.system.systemState + "</p>" +
                "<p><b>Final State:</b> " + result.final_state + "</p>" +
                "<p><b>Interpretation:</b> " + result.interpretation + "</p>";

            return;
        }

        // NORMAL MODE
        if (type === "normal") {
            status.innerText = "HEALTHY";
            output.innerHTML = "SYSTEM RUNNING NORMALLY";
            return;
        }

        // FAILURE MODE
        if (type === "failure") {
            status.innerText = "DEGRADED";
            output.innerHTML = "FAILURE SIMULATION ACTIVE";
            return;
        }

    } catch (e) {

        console.error(e);

        status.innerText = "SAFE MODE";
        output.innerHTML =
            "❌ ENGINE ERROR DETECTED<br>System switched to safe mode";
    }
}


// ----------------------------
// OPTIONAL EXPORT FUNCTION
// ----------------------------
function exportAudit() {

    if (!window.lastSimulationResult) {
        alert("No simulation data available");
        return;
    }

    const report = {
        report_id: "SEXTANT-" + Date.now(),
        timestamp: new Date().toISOString(),
        data: window.lastSimulationResult
    };

    const blob = new Blob(
        [JSON.stringify(report, null, 2)],
        { type: "application/json" }
    );

    const url = URL.createObjectURL(blob);

    const a = document.createElement("a");
    a.href = url;
    a.download = report.report_id + ".json";
    a.click();

    URL.revokeObjectURL(url);
}
